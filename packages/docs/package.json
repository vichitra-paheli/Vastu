{
  "name": "@vastu/docs",
  "version": "0.0.0",
  "private": true,
  "description": "Developer documentation site built with Fumadocs",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "postinstall": "fumadocs-mdx",
    "typecheck": "fumadocs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "fumadocs-core": "^14.7.7",
    "fumadocs-mdx": "^10.1.0",
    "fumadocs-ui": "^14.7.7",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  }
}
