// Vastu Prisma Schema
// All field names: camelCase in Prisma, mapped to snake_case in DB
// All tables: id (UUID), createdAt, updatedAt
// User-facing tables: soft-delete via deletedAt

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SANDBOX
}

enum SsoProviderType {
  SAML
  OIDC
}

enum SsoProviderStatus {
  LIVE
  DRAFT
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

model Organization {
  id               String    @id @default(uuid())
  name             String
  logoUrl          String?   @map("logo_url")
  workspaceUrl     String?   @map("workspace_url")
  defaultTimezone  String    @default("UTC") @map("default_timezone")
  defaultLanguage  String    @default("en") @map("default_language")
  ssoRequired      Boolean   @default(false) @map("sso_required")
  mfaRequired      Boolean   @default(false) @map("mfa_required")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  users         User[]
  tenants       Tenant[]
  roles         Role[]
  apiKeys       ApiKey[]
  dbConnections DbConnection[]
  ssoProviders  SsoProvider[]
  auditEvents   AuditEvent[]
  pages         Page[]
  views         View[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  avatarUrl      String?   @map("avatar_url")
  emailVerified  Boolean   @default(false) @map("email_verified")
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaSecret           String?   @map("mfa_secret")
  mfaRecoveryCodes    String?   @map("mfa_recovery_codes")
  language            String    @default("en")
  timezone       String    @default("UTC")
  colorScheme    String    @default("system") @map("color_scheme")
  accentColor    String    @default("#4C6EF5") @map("accent_color")
  density        String    @default("comfortable")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  userRoles    UserRole[]
  apiKeys      ApiKey[]
  auditEvents  AuditEvent[]
  sessions     Session[]
  accounts     Account[]
  views        View[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------

model Tenant {
  id              String       @id @default(uuid())
  name            String
  subdomain       String       @unique
  status          TenantStatus @default(ACTIVE)
  region          String?
  dbIsolationMode String       @default("shared_schema") @map("db_isolation_mode")
  organizationId  String       @map("organization_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  userRoles    UserRole[]
  ssoProviders SsoProvider[]
  auditEvents  AuditEvent[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Role
// ---------------------------------------------------------------------------

model Role {
  id             String    @id @default(uuid())
  name           String
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  baseRoleId     String?   @map("base_role_id")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id])
  baseRole      Role?        @relation("RoleInheritance", fields: [baseRoleId], references: [id])
  derivedRoles  Role[]       @relation("RoleInheritance")
  userRoles     UserRole[]
  permissions   Permission[]

  @@unique([name, organizationId])
  @@map("roles")
}

// ---------------------------------------------------------------------------
// UserRole
// ---------------------------------------------------------------------------

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  tenantId  String?  @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([userId, roleId, tenantId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Permission
// ---------------------------------------------------------------------------

model Permission {
  id         String   @id @default(uuid())
  roleId     String   @map("role_id")
  resource   String
  action     String
  granted    Boolean  @default(true)
  conditions Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, resource, action])
  @@map("permissions")
}

// ---------------------------------------------------------------------------
// ApiKey
// ---------------------------------------------------------------------------

model ApiKey {
  id               String    @id @default(uuid())
  name             String
  keyHash          String    @map("key_hash")
  keyPrefix        String    @map("key_prefix")
  scope            String    @default("full")
  description      String?
  lastUsedAt       DateTime? @map("last_used_at")
  requestCount24h  Int       @default(0) @map("request_count_24h")
  userId           String    @map("user_id")
  organizationId   String    @map("organization_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([keyHash])
  @@index([organizationId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// DbConnection
// ---------------------------------------------------------------------------

model DbConnection {
  id                String    @id @default(uuid())
  name              String
  host              String
  port              Int
  database          String
  username          String
  encryptedPassword String    @map("encrypted_password")
  sslEnabled        Boolean   @default(false) @map("ssl_enabled")
  protocol          String    @default("postgresql")
  healthStatus      String    @default("unknown") @map("health_status")
  lastHealthCheck   DateTime? @map("last_health_check")
  organizationId    String    @map("organization_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("db_connections")
}

// ---------------------------------------------------------------------------
// SsoProvider
// ---------------------------------------------------------------------------

model SsoProvider {
  id                    String            @id @default(uuid())
  name                  String
  type                  SsoProviderType
  status                SsoProviderStatus @default(DRAFT)
  isDefault             Boolean           @default(false) @map("is_default")
  clientId              String?           @map("client_id")
  encryptedClientSecret String?           @map("encrypted_client_secret")
  issuerUrl             String?           @map("issuer_url")
  metadataUrl           String?           @map("metadata_url")
  redirectUri           String?           @map("redirect_uri")
  enabled               Boolean           @default(false)
  organizationId        String            @map("organization_id")
  tenantId              String?           @map("tenant_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([organizationId])
  @@map("sso_providers")
}

// ---------------------------------------------------------------------------
// AuditEvent (immutable, append-only — no updatedAt)
// ---------------------------------------------------------------------------

model AuditEvent {
  id                  String    @id @default(uuid())
  userId              String?   @map("user_id")
  userName            String?   @map("user_name")
  action              String
  resourceType        String    @map("resource_type")
  resourceId          String?   @map("resource_id")
  resourceDescription String?   @map("resource_description")
  payload             Json?
  beforeState         Json?     @map("before_state")
  afterState          Json?     @map("after_state")
  ipAddress           String?   @map("ip_address")
  userAgent           String?   @map("user_agent")
  tenantId            String?   @map("tenant_id")
  organizationId      String    @map("organization_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  user         User?        @relation(fields: [userId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// next-auth tables (@auth/prisma-adapter compatible)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Page — registered page definitions (US-110)
// ---------------------------------------------------------------------------

model Page {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  icon           String?
  templateType   String    @map("template_type")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  views        View[]

  @@index([organizationId])
  @@map("pages")
}

// ---------------------------------------------------------------------------
// View — saved view state snapshots (US-110)
// ---------------------------------------------------------------------------

model View {
  id             String    @id @default(uuid())
  name           String
  pageId         String    @map("page_id")
  stateJson      Json      @map("state_json")
  createdBy      String    @map("created_by")
  isShared       Boolean   @default(false) @map("is_shared")
  colorDot       String?   @map("color_dot")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  page          Page         @relation(fields: [pageId], references: [id])
  createdByUser User         @relation(fields: [createdBy], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([pageId])
  @@index([createdBy])
  @@index([organizationId])
  @@map("views")
}
