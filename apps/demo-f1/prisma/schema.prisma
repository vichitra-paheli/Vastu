// demo-f1 Prisma Schema
// Generated by vastu:init — extends the Vastu base schema
// All field names: camelCase in Prisma, mapped to snake_case in DB
// All tables: id (UUID), createdAt, updatedAt
// User-facing tables: soft-delete via deletedAt

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums — base framework
// ---------------------------------------------------------------------------

enum TenantStatus {
  ACTIVE
  SANDBOX
}

enum SsoProviderType {
  SAML
  OIDC
}

enum SsoProviderStatus {
  LIVE
  DRAFT
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

model Organization {
  id               String    @id @default(uuid())
  name             String
  logoUrl          String?   @map("logo_url")
  workspaceUrl     String?   @map("workspace_url")
  defaultTimezone  String    @default("UTC") @map("default_timezone")
  defaultLanguage  String    @default("en") @map("default_language")
  ssoRequired      Boolean   @default(false) @map("sso_required")
  mfaRequired      Boolean   @default(false) @map("mfa_required")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  users         User[]
  tenants       Tenant[]
  roles         Role[]
  apiKeys       ApiKey[]
  dbConnections DbConnection[]
  ssoProviders  SsoProvider[]
  auditEvents   AuditEvent[]
  pages         Page[]
  views         View[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String
  avatarUrl           String?   @map("avatar_url")
  emailVerified       Boolean   @default(false) @map("email_verified")
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaSecret           String?   @map("mfa_secret")
  mfaRecoveryCodes    String?   @map("mfa_recovery_codes")
  language            String    @default("en")
  timezone            String    @default("UTC")
  colorScheme         String    @default("system") @map("color_scheme")
  accentColor         String    @default("#4C6EF5") @map("accent_color")
  density             String    @default("comfortable")
  organizationId      String    @map("organization_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  userRoles    UserRole[]
  apiKeys      ApiKey[]
  auditEvents  AuditEvent[]
  sessions     Session[]
  accounts     Account[]
  views        View[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------

model Tenant {
  id              String       @id @default(uuid())
  name            String
  subdomain       String       @unique
  status          TenantStatus @default(ACTIVE)
  region          String?
  dbIsolationMode String       @default("shared_schema") @map("db_isolation_mode")
  organizationId  String       @map("organization_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  userRoles    UserRole[]
  ssoProviders SsoProvider[]
  auditEvents  AuditEvent[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Role
// ---------------------------------------------------------------------------

model Role {
  id             String    @id @default(uuid())
  name           String
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  baseRoleId     String?   @map("base_role_id")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id])
  baseRole      Role?        @relation("RoleInheritance", fields: [baseRoleId], references: [id])
  derivedRoles  Role[]       @relation("RoleInheritance")
  userRoles     UserRole[]
  permissions   Permission[]

  @@unique([name, organizationId])
  @@map("roles")
}

// ---------------------------------------------------------------------------
// UserRole
// ---------------------------------------------------------------------------

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  tenantId  String?  @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([userId, roleId, tenantId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Permission
// ---------------------------------------------------------------------------

model Permission {
  id         String   @id @default(uuid())
  roleId     String   @map("role_id")
  resource   String
  action     String
  granted    Boolean  @default(true)
  conditions Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, resource, action])
  @@map("permissions")
}

// ---------------------------------------------------------------------------
// ApiKey
// ---------------------------------------------------------------------------

model ApiKey {
  id               String    @id @default(uuid())
  name             String
  keyHash          String    @map("key_hash")
  keyPrefix        String    @map("key_prefix")
  scope            String    @default("full")
  description      String?
  lastUsedAt       DateTime? @map("last_used_at")
  requestCount24h  Int       @default(0) @map("request_count_24h")
  userId           String    @map("user_id")
  organizationId   String    @map("organization_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([keyHash])
  @@index([organizationId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// DbConnection
// ---------------------------------------------------------------------------

model DbConnection {
  id                String    @id @default(uuid())
  name              String
  host              String
  port              Int
  database          String
  username          String
  encryptedPassword String    @map("encrypted_password")
  sslEnabled        Boolean   @default(false) @map("ssl_enabled")
  protocol          String    @default("postgresql")
  healthStatus      String    @default("unknown") @map("health_status")
  lastHealthCheck   DateTime? @map("last_health_check")
  organizationId    String    @map("organization_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("db_connections")
}

// ---------------------------------------------------------------------------
// SsoProvider
// ---------------------------------------------------------------------------

model SsoProvider {
  id                    String            @id @default(uuid())
  name                  String
  type                  SsoProviderType
  status                SsoProviderStatus @default(DRAFT)
  isDefault             Boolean           @default(false) @map("is_default")
  clientId              String?           @map("client_id")
  encryptedClientSecret String?           @map("encrypted_client_secret")
  issuerUrl             String?           @map("issuer_url")
  metadataUrl           String?           @map("metadata_url")
  redirectUri           String?           @map("redirect_uri")
  enabled               Boolean           @default(false)
  organizationId        String            @map("organization_id")
  tenantId              String?           @map("tenant_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([organizationId])
  @@map("sso_providers")
}

// ---------------------------------------------------------------------------
// AuditEvent (immutable, append-only — no updatedAt)
// ---------------------------------------------------------------------------

model AuditEvent {
  id                  String    @id @default(uuid())
  userId              String?   @map("user_id")
  userName            String?   @map("user_name")
  action              String
  resourceType        String    @map("resource_type")
  resourceId          String?   @map("resource_id")
  resourceDescription String?   @map("resource_description")
  payload             Json?
  beforeState         Json?     @map("before_state")
  afterState          Json?     @map("after_state")
  ipAddress           String?   @map("ip_address")
  userAgent           String?   @map("user_agent")
  tenantId            String?   @map("tenant_id")
  organizationId      String    @map("organization_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  user         User?        @relation(fields: [userId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// next-auth tables (@auth/prisma-adapter compatible)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Page — registered page definitions (US-110)
// ---------------------------------------------------------------------------

model Page {
  id             String    @id @default(uuid())
  name           String
  slug           String
  icon           String?
  templateType   String    @map("template_type")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  views        View[]

  @@unique([slug, organizationId])
  @@index([organizationId])
  @@map("pages")
}

// ---------------------------------------------------------------------------
// View — saved view state snapshots (US-110)
// ---------------------------------------------------------------------------

model View {
  id             String    @id @default(uuid())
  name           String
  pageId         String    @map("page_id")
  stateJson      Json      @map("state_json")
  createdBy      String    @map("created_by")
  isShared       Boolean   @default(false) @map("is_shared")
  colorDot       String?   @map("color_dot")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  page          Page         @relation(fields: [pageId], references: [id])
  createdByUser User         @relation(fields: [createdBy], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([pageId])
  @@index([createdBy])
  @@index([organizationId])
  @@map("views")
}

// ═══════════════════════════════════════
// YOUR DOMAIN MODELS BELOW
// ═══════════════════════════════════════

// ---------------------------------------------------------------------------
// F1 Domain Enums
// ---------------------------------------------------------------------------

enum CircuitType {
  Street
  Permanent
  SemiPermanent
}

enum ConstructorStatus {
  Active
  Withdrawn
}

enum DriverStatus {
  Active
  Retired
  Reserve
}

enum RaceStatus {
  Scheduled
  Completed
  Cancelled
}

enum WeatherCondition {
  Dry
  Wet
  Mixed
}

enum RaceResultStatus {
  Finished
  DNF
  DSQ
  DNS
}

enum TireCompound {
  Soft
  Medium
  Hard
  Intermediate
  Wet
}

enum RaceEventType {
  Start
  PitStop
  Overtake
  Penalty
  SafetyCar
  RedFlag
  Retirement
  FastestLap
  Finish
}

enum PenaltyType {
  TimePenalty
  GridPenalty
  DriveThrough
  StopGo
  Reprimand
  Disqualification
}

// ---------------------------------------------------------------------------
// F1 Core — Seasons, Circuits, Constructors, Drivers
// ---------------------------------------------------------------------------

/// A Formula 1 season (one per calendar year).
model Season {
  id                    String   @id @default(uuid())
  /// Calendar year, e.g. 2024. Must be unique.
  year                  Int      @unique
  /// Number of races in the season.
  rounds                Int
  /// Optional: the driver who won the championship this season.
  championDriverId      String?  @map("champion_driver_id")
  /// Optional: the constructor that won the championship this season.
  championConstructorId String?  @map("champion_constructor_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  championDriver      Driver?      @relation("SeasonChampionDriver", fields: [championDriverId], references: [id])
  championConstructor Constructor? @relation("SeasonChampionConstructor", fields: [championConstructorId], references: [id])
  races               Race[]

  @@index([year])
  @@map("seasons")
}

/// A racing circuit (track).
model Circuit {
  id              String      @id @default(uuid())
  /// Full circuit name, e.g. "Circuit de Monaco".
  name            String
  /// City or locality, e.g. "Monte Carlo".
  location        String
  /// Country, e.g. "Monaco".
  country         String
  /// Track length in kilometres.
  lengthKm        Float       @map("length_km")
  /// Number of turns on the circuit.
  turns           Int
  /// Lap record in milliseconds (nullable until set).
  lapRecordMs     Int?        @map("lap_record_ms")
  /// Driver who holds the lap record.
  lapRecordDriverId String?   @map("lap_record_driver_id")
  /// Year of first Grand Prix held here.
  firstGpYear     Int         @map("first_gp_year")
  /// Track altitude in metres above sea level.
  altitudeM       Int         @map("altitude_m")
  /// Circuit classification (Street/Permanent/SemiPermanent).
  circuitType     CircuitType @map("circuit_type")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  lapRecordDriver Driver? @relation("CircuitLapRecord", fields: [lapRecordDriverId], references: [id])
  races           Race[]

  @@index([country])
  @@map("circuits")
}

/// A constructor (team) competing in Formula 1.
/// Uses soft-delete so historical records remain intact.
model Constructor {
  id              String            @id @default(uuid())
  /// Short name used in standings, e.g. "Red Bull".
  name            String
  /// Full official name, e.g. "Oracle Red Bull Racing".
  fullName        String            @map("full_name")
  /// Nationality of the constructor.
  nationality     String
  /// HQ city / country, e.g. "Milton Keynes, UK".
  base            String
  /// Team principal name.
  teamPrincipal   String            @map("team_principal")
  /// Engine supplier, e.g. "Honda RBPT".
  engineSupplier  String            @map("engine_supplier")
  /// Year the team first entered F1.
  firstEntryYear  Int               @map("first_entry_year")
  /// Number of constructors' championships won.
  championships   Int               @default(0)
  /// Whether the team is currently active.
  status          ConstructorStatus @default(Active)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  /// Soft-delete timestamp. Null = active record.
  deletedAt       DateTime?         @map("deleted_at")

  races                  Race[]                 @relation("RaceConstructors")
  raceResults            RaceResult[]
  qualifyingResults      QualifyingResult[]
  sprintResults          SprintResult[]
  constructorStandings   ConstructorStanding[]
  championSeasons        Season[]               @relation("SeasonChampionConstructor")

  @@index([nationality])
  @@map("constructors")
}

/// A driver competing in Formula 1.
/// Uses soft-delete so historical records remain intact.
model Driver {
  id            String       @id @default(uuid())
  /// Three-letter driver code, e.g. "VER". Unique across all time.
  abbreviation  String       @unique
  /// Given name.
  firstName     String       @map("first_name")
  /// Family name.
  lastName      String       @map("last_name")
  /// Race number (1–99). Drivers keep their number across seasons.
  number        Int
  /// Driver's nationality.
  nationality   String
  /// Date of birth.
  dateOfBirth   DateTime     @map("date_of_birth")
  /// Number of drivers' championships won.
  championships Int          @default(0)
  /// Career race wins.
  wins          Int          @default(0)
  /// Career podium finishes.
  podiums       Int          @default(0)
  /// Career pole positions.
  poles         Int          @default(0)
  /// Current status: Active / Retired / Reserve.
  status        DriverStatus @default(Active)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  /// Soft-delete timestamp. Null = active record.
  deletedAt     DateTime?    @map("deleted_at")

  raceResults          RaceResult[]
  qualifyingResults    QualifyingResult[]
  sprintResults        SprintResult[]
  pitStops             PitStop[]
  lapTimes             LapTime[]
  driverStandings      DriverStanding[]
  raceEvents           RaceEvent[]
  penalties            Penalty[]
  circuitLapRecords    Circuit[]          @relation("CircuitLapRecord")
  championSeasons      Season[]           @relation("SeasonChampionDriver")

  @@index([abbreviation])
  @@index([nationality])
  @@map("drivers")
}

// ---------------------------------------------------------------------------
// F1 Race Weekend — Races, Results, Qualifying, Sprints
// ---------------------------------------------------------------------------

/// A scheduled or completed Grand Prix race weekend.
model Race {
  id             String          @id @default(uuid())
  /// The season this race belongs to.
  seasonId       String          @map("season_id")
  /// The circuit where this race is held.
  circuitId      String          @map("circuit_id")
  /// Round number within the season (1-based).
  round          Int
  /// Full race name, e.g. "Monaco Grand Prix".
  name           String
  /// Race date (UTC).
  date           DateTime
  /// Race lifecycle status.
  status         RaceStatus      @default(Scheduled)
  /// Weather conditions during the race.
  weather        WeatherCondition @default(Dry)
  /// Number of laps completed by the race winner.
  lapsCompleted  Int             @map("laps_completed")
  /// Scheduled total lap count.
  totalLaps      Int             @map("total_laps")
  /// Whether a sprint race was held this weekend.
  hasSprint      Boolean         @default(false) @map("has_sprint")
  /// Number of laps run under Safety Car.
  safetyCatLaps  Int             @default(0) @map("safety_car_laps")
  /// Number of Red Flag stoppages.
  redFlagCount   Int             @default(0) @map("red_flag_count")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  season               Season               @relation(fields: [seasonId], references: [id])
  circuit              Circuit              @relation(fields: [circuitId], references: [id])
  constructors         Constructor[]        @relation("RaceConstructors")
  raceResults          RaceResult[]
  qualifyingResults    QualifyingResult[]
  sprintResults        SprintResult[]
  pitStops             PitStop[]
  lapTimes             LapTime[]
  driverStandings      DriverStanding[]
  constructorStandings ConstructorStanding[]
  raceEvents           RaceEvent[]
  penalties            Penalty[]

  @@unique([seasonId, round])
  @@index([seasonId])
  @@index([circuitId])
  @@index([date])
  @@map("races")
}

/// Final race classification result for one driver.
model RaceResult {
  id                String           @id @default(uuid())
  raceId            String           @map("race_id")
  driverId          String           @map("driver_id")
  constructorId     String           @map("constructor_id")
  /// Grid starting position.
  gridPosition      Int              @map("grid_position")
  /// Final finishing position. Null if not classified.
  finishPosition    Int?             @map("finish_position")
  /// Result classification.
  status            RaceResultStatus @default(Finished)
  /// Human-readable detail, e.g. "Mechanical failure".
  statusDetail      String?          @map("status_detail")
  /// Championship points scored.
  points            Float            @default(0)
  /// Number of laps completed.
  lapsCompleted     Int              @map("laps_completed")
  /// Total race time in milliseconds. Null for non-finishers.
  totalTimeMs       Int?             @map("total_time_ms")
  /// Whether this driver set the fastest lap of the race.
  fastestLap        Boolean          @default(false) @map("fastest_lap")
  /// Fastest lap time in milliseconds.
  fastestLapTimeMs  Int?             @map("fastest_lap_time_ms")
  /// Gap to race leader in milliseconds. Null for leader.
  gapToLeaderMs     Int?             @map("gap_to_leader_ms")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  race        Race        @relation(fields: [raceId], references: [id])
  driver      Driver      @relation(fields: [driverId], references: [id])
  constructor Constructor @relation(fields: [constructorId], references: [id])

  @@unique([raceId, driverId])
  @@index([raceId])
  @@index([driverId])
  @@index([constructorId])
  @@index([finishPosition])
  @@map("race_results")
}

/// Qualifying session result for one driver.
model QualifyingResult {
  id            String   @id @default(uuid())
  raceId        String   @map("race_id")
  driverId      String   @map("driver_id")
  constructorId String   @map("constructor_id")
  /// Final qualifying classification position.
  position      Int
  /// Q1 lap time in milliseconds.
  q1TimeMs      Int?     @map("q1_time_ms")
  /// Q2 lap time in milliseconds. Null if eliminated in Q1.
  q2TimeMs      Int?     @map("q2_time_ms")
  /// Q3 lap time in milliseconds. Null if eliminated before Q3.
  q3TimeMs      Int?     @map("q3_time_ms")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  race        Race        @relation(fields: [raceId], references: [id])
  driver      Driver      @relation(fields: [driverId], references: [id])
  constructor Constructor @relation(fields: [constructorId], references: [id])

  @@unique([raceId, driverId])
  @@index([raceId])
  @@index([driverId])
  @@index([constructorId])
  @@index([position])
  @@map("qualifying_results")
}

/// Sprint race result for one driver (when hasSprint = true).
model SprintResult {
  id             String   @id @default(uuid())
  raceId         String   @map("race_id")
  driverId       String   @map("driver_id")
  constructorId  String   @map("constructor_id")
  /// Grid starting position for the sprint.
  gridPosition   Int      @map("grid_position")
  /// Sprint finishing position.
  finishPosition Int      @map("finish_position")
  /// Championship points scored in the sprint.
  points         Float    @default(0)
  /// Laps completed in the sprint.
  lapsCompleted  Int      @map("laps_completed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  race        Race        @relation(fields: [raceId], references: [id])
  driver      Driver      @relation(fields: [driverId], references: [id])
  constructor Constructor @relation(fields: [constructorId], references: [id])

  @@unique([raceId, driverId])
  @@index([raceId])
  @@index([driverId])
  @@index([constructorId])
  @@map("sprint_results")
}

// ---------------------------------------------------------------------------
// F1 Granular — Pit Stops, Lap Times
// ---------------------------------------------------------------------------

/// A single pit stop entry for a driver during a race.
model PitStop {
  id           String       @id @default(uuid())
  raceId       String       @map("race_id")
  driverId     String       @map("driver_id")
  /// Lap number on which the pit stop occurred.
  lap          Int
  /// Sequential pit stop number for this driver in this race (1, 2, 3…).
  stopNumber   Int          @map("stop_number")
  /// Pit stop duration in milliseconds (stationary time + entry/exit).
  durationMs   Int          @map("duration_ms")
  /// Tire compound fitted during this stop.
  tireCompound TireCompound @map("tire_compound")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  race   Race   @relation(fields: [raceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([raceId, driverId, stopNumber])
  @@index([raceId])
  @@index([driverId])
  @@index([lap])
  @@map("pit_stops")
}

/// Individual lap time for a driver in a race.
/// High-volume table — always paginated server-side.
model LapTime {
  id             String   @id @default(uuid())
  raceId         String   @map("race_id")
  driverId       String   @map("driver_id")
  /// Lap number (1-based).
  lapNumber      Int      @map("lap_number")
  /// Total lap time in milliseconds.
  timeMs         Int      @map("time_ms")
  /// Track position at the end of this lap.
  position       Int
  /// Sector 1 time in milliseconds.
  sector1Ms      Int      @map("sector_1_ms")
  /// Sector 2 time in milliseconds.
  sector2Ms      Int      @map("sector_2_ms")
  /// Sector 3 time in milliseconds.
  sector3Ms      Int      @map("sector_3_ms")
  /// Whether this was a personal best for the driver at this circuit.
  isPersonalBest Boolean  @default(false) @map("is_personal_best")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  race   Race   @relation(fields: [raceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([raceId, driverId, lapNumber])
  @@index([raceId])
  @@index([driverId])
  @@index([lapNumber])
  @@index([timeMs])
  @@map("lap_times")
}

// ---------------------------------------------------------------------------
// F1 Standings — after each race
// ---------------------------------------------------------------------------

/// Driver championship standings snapshot after a specific race.
model DriverStanding {
  id       String   @id @default(uuid())
  raceId   String   @map("race_id")
  driverId String   @map("driver_id")
  /// Accumulated championship points after this race.
  points   Float
  /// Championship position after this race.
  position Int
  /// Race wins accumulated to this point.
  wins     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  race   Race   @relation(fields: [raceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([raceId, driverId])
  @@index([raceId])
  @@index([driverId])
  @@index([position])
  @@map("driver_standings")
}

/// Constructor championship standings snapshot after a specific race.
model ConstructorStanding {
  id            String   @id @default(uuid())
  raceId        String   @map("race_id")
  constructorId String   @map("constructor_id")
  /// Accumulated championship points after this race.
  points        Float
  /// Championship position after this race.
  position      Int
  /// Race wins accumulated to this point.
  wins          Int
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  race        Race        @relation(fields: [raceId], references: [id])
  constructor Constructor @relation(fields: [constructorId], references: [id])

  @@unique([raceId, constructorId])
  @@index([raceId])
  @@index([constructorId])
  @@index([position])
  @@map("constructor_standings")
}

// ---------------------------------------------------------------------------
// F1 Events — Race events and penalties (for timeline template)
// ---------------------------------------------------------------------------

/// A notable event that occurred during a race (used by the timeline template).
model RaceEvent {
  id          String        @id @default(uuid())
  raceId      String        @map("race_id")
  /// Lap on which the event occurred.
  lap         Int
  /// Event classification.
  type        RaceEventType
  /// Driver involved (optional — SafetyCar/RedFlag may have no driver).
  driverId    String?       @map("driver_id")
  /// Human-readable description of the event.
  description String
  /// Timestamp of the event (race clock).
  timestamp   DateTime
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  race   Race    @relation(fields: [raceId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])

  @@index([raceId])
  @@index([driverId])
  @@index([type])
  @@index([lap])
  @@map("race_events")
}

/// A penalty issued to a driver during or after a race.
model Penalty {
  id          String      @id @default(uuid())
  raceId      String      @map("race_id")
  driverId    String      @map("driver_id")
  /// Lap on which the infringement occurred.
  lap         Int
  /// Penalty type.
  type        PenaltyType
  /// Seconds penalty (for TimePenalty). Null for other types.
  seconds     Int?
  /// Grid places penalty (for GridPenalty). Null for other types.
  gridPlaces  Int?        @map("grid_places")
  /// Reason given by stewards.
  reason      String
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  race   Race   @relation(fields: [raceId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([raceId])
  @@index([driverId])
  @@map("penalties")
}
