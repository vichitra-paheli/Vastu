# =============================================================================
# Vastu — environment variables
# Copy this file to .env and fill in values for your environment.
# All services below are provided by docker compose (see docker-compose.yml).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# Override POSTGRES_PORT if you need to run postgres on a different host port.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://vastu:vastu@localhost:5432/vastu
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis 7
# Override REDIS_PORT if 6379 is already in use on your machine.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Keycloak 24
# KEYCLOAK_URL — base URL of the Keycloak server (no trailing slash)
# KEYCLOAK_REALM — realm name (pre-configured as 'vastu' via realm-export.json)
# KEYCLOAK_CLIENT_ID — OIDC client id registered in the realm
# KEYCLOAK_CLIENT_SECRET — OIDC client secret (set to 'dev-secret' in dev realm)
# Override KEYCLOAK_PORT if 8080 is already in use.
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=vastu
KEYCLOAK_CLIENT_ID=vastu-app
KEYCLOAK_CLIENT_SECRET=dev-secret
# KEYCLOAK_PORT=8080

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_SECRET must be a long random string in production.
# Generate one with: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# MINIO_PORT — S3 API port
# MINIO_CONSOLE_PORT — Web console port (default 9001)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vastu-uploads
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Encryption key
# Used to encrypt database connection credentials and SSO secrets at rest.
# Must be a 32-byte (256-bit) hex string in production.
# Generate one with: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
